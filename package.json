{
  "name": "linkwarden-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Linkwarden — read, search, and organize your self-hosted bookmarks via Claude",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "linkwarden-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "linkwarden",
    "bookmarks",
    "claude",
    "ai",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozskywalker/linkwarden-mcp-server.git"
  },
  "homepage": "https://github.com/ozskywalker/linkwarden-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/ozskywalker/linkwarden-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
